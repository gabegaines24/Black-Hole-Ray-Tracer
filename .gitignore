# --- Project Files ---
plan.txt

# --- C / Compiled Binaries ---
*.o
*.obj
*.so
*.dll
*.dylib
*.exe
dist/
# build/ directory — track .gitkeep but ignore compiled artefacts
build/*.so
build/*.dll
build/*.dylib
build/*.exe

# setuptools / editable install metadata (do not commit)
*.egg-info/
.eggs/

# --- Ray tracer binary outputs ---
*.ppm


# Kernel build artefacts
kernel/harmonic_demo
kernel/harmonic_demo.exe
kernel/schwarzschild_demo
kernel/schwarzschild_demo.exe
kernel/schwarzschild3d_demo
kernel/schwarzschild3d_demo.exe
kernel/phase2_batch_demo
kernel/phase2_batch_demo.exe

*.py[cod]
*$py.class
.venv/
venv/
env/
.env
.pytest_cache/

# --- Machine Learning Artifacts ---
# Ignore large model weights and datasets
*.pth
*.pt
*.h5
*.joblib
# Large dataset / model files inside ml/
ml/data/*.npz
ml/models/*.npz
# Keep placeholder dirs tracked
!ml/data/.gitkeep
!ml/models/.gitkeep

# --- IDEs and OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
